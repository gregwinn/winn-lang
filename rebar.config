{erl_opts, [debug_info]}.

{deps, [
    {epgsql, "4.7.1"},
    {hackney, "1.20.1"},
    {jsone, "1.8.1"},
    {gun, "2.1.0"},
    {cowboy, "2.12.0"}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]}
    ]}
]}.

%% escript for the `winn` CLI tool
{escript_main_app, winn}.
{escript_name, winn}.
{escript_emu_args, "%%! -escript main winn_cli\n"}.
