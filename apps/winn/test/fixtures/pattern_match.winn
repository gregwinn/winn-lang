# Pattern matching example — demonstrates Phase 2 features.

module Result

  def unwrap({:ok, value})
    value
  end

  def unwrap({:error, reason})
    IO.puts("Error: " <> reason)
    :error
  end

  def process(input)
    input
      |> match
        ok value  => value
        err msg   => msg
      end
  end

  def describe({:user, name, age})
    "User: " <> name
  end

  def describe(:anonymous)
    "Anonymous user"
  end

end
